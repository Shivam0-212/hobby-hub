<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ==============================
       META & HEAD SECTION
  ============================== -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css" />
</head>

<body>

  <!-- ==============================
       HEADER & NAVIGATION
  ============================== -->
  <header class="site-header">
    <div class="container">
      <div class="logo">
        <a href="/">🎯 Hobby Hub</a>
      </div>
      <nav class="main-nav" aria-label="Main Navigation">
        <ul class="nav-list">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/explore" class="nav-link active">Explore Hobbies</a></li>
          <li><a href="/add" class="nav-link">Add Hobby</a></li>
          <li><a href="/community" class="nav-link">Community</a></li>
          <li><a href="/dashboard" class="nav-link">Dashboard</a></li>
          <li><a href="/about" class="nav-link">About / Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- ==============================
       MAIN CONTENT
  ============================== -->
  <main>

    <!-- Page Hero / Banner -->
    <section class="page-hero" aria-label="Page Header">
      <div class="container">
        <h1>Explore Hobbies</h1>
        <p>Browse our full collection of hobbies. Use the category filters to narrow down your search.</p>
      </div>
    </section>

    <!-- ==============================
         FILTER SECTION
         Category filter buttons to narrow down hobbies
    ============================== -->
    <section class="filter-section" aria-label="Category Filters">
      <div class="container">
        <div class="filter-buttons">
          <!--
            EJS Loop: Render one filter button per category
            The "active" class is added if this category is currently selected
          -->
          <% categories.forEach(function(category) { %>
            <a
              href="/explore<%= category !== 'All' ? '?category=' + encodeURIComponent(category) : '' %>"
              class="filter-btn <%= selectedCategory === category ? 'active' : '' %>"
            >
              <%= category %>
            </a>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- ==============================
         HOBBIES LISTING SECTION
         Displays all hobbies or filtered results
    ============================== -->
    <section class="hobbies-section" aria-label="Hobbies List">
      <div class="container">

        <!-- Results count -->
        <p class="results-count">
          Showing <strong><%= hobbies.length %></strong>
          <%= selectedCategory !== 'All' ? 'hobbies in ' + selectedCategory : 'hobbies' %>
        </p>

        <!-- ==============================
             CONDITIONAL: Show hobbies OR empty message
             EJS if/else to handle empty state
        ============================== -->
        <% if (hobbies.length === 0) { %>
          <!-- Empty state when no hobbies match the filter -->
          <div class="empty-state">
            <p>No hobbies found in this category.</p>
            <a href="/explore" class="btn btn-primary">View All Hobbies</a>
          </div>
        <% } else { %>
          <!-- Hobby cards grid -->
          <div class="hobbies-grid">
            <% hobbies.forEach(function(hobby) { %>
              <!-- Each hobby is an <article> element -->
              <article class="hobby-card">
                <div class="card-image">
                  <img src="<%= hobby.image %>" alt="<%= hobby.title %>" loading="lazy" />
                  <span class="category-badge"><%= hobby.category %></span>
                </div>
                <div class="card-body">
                  <h3 class="card-title"><%= hobby.title %></h3>
                  <p class="card-description"><%= hobby.description %></p>
                  <div class="card-meta">
                    <span class="meta-item">
                      <strong>Difficulty:</strong> <%= hobby.difficulty %>
                    </span>
                    <span class="meta-item">
                      <strong>Time:</strong> <%= hobby.timeRequired %>
                    </span>
                  </div>
                </div>
                <div class="card-footer">
                  <span class="difficulty-badge difficulty-<%= hobby.difficulty.toLowerCase() %>">
                    <%= hobby.difficulty %>
                  </span>
                  <a href="/edit/<%= hobby.id %>" class="btn btn-outline" style="font-size:0.8rem;padding:4px 12px;">
                    ✏️ Edit
                  </a>
                </div>
              </article>
            <% }); %>
          </div>
        <% } %>

      </div>
    </section>

  </main>

  <!-- ==============================
       FOOTER
  ============================== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>🎯 Hobby Hub</h3>
          <p>Connecting people with their passions since 2024.</p>
        </div>
        <nav class="footer-nav" aria-label="Footer Navigation">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/explore">Explore Hobbies</a></li>
            <li><a href="/add">Add Hobby</a></li>
            <li><a href="/dashboard">Dashboard</a></li>
            <li><a href="/about">About / Contact</a></li>
          </ul>
        </nav>
        <div class="footer-contact">
          <h4>Contact</h4>
          <p>Email: shivam.agrawal2024@vitstudent.ac.in</p>
          <p>Phone: +91 8948203320</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 Hobby Hub. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
